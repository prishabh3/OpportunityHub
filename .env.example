# Root-level reference for the local docker-compose infra (infra/docker-compose.yml).
# Application config lives in backend/.env.example and frontend/.env.local.example —
# copy those to backend/.env and frontend/.env.local respectively.

# Postgres (pgvector/pgvector:pg16), exposed on host port 5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=opportunityhub

# Redis (redis:7-alpine), exposed on host port 6379

# Meilisearch (getmeili/meilisearch:v1.10), exposed on host port 7700
MEILI_MASTER_KEY=masterKey
MEILI_ENV=development
