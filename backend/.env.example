# General
ENVIRONMENT=development
DEBUG=true

# CORS (comma-separated list, parsed by pydantic-settings)
CORS_ORIGINS=["http://localhost:3000"]

# Database (Postgres + pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/opportunityhub

# Redis
# Host port 6380 (mapped to the container's 6379 in infra/docker-compose.yml,
# remapped to avoid clashing with a local/other Redis already on 6379).
REDIS_URL=redis://localhost:6380/0

# Number of reverse proxies in front of the API that append to X-Forwarded-For.
# 0 (local, reachable directly) means the header is ignored entirely and the
# socket peer is used. Production behind Render's TLS proxy sets 1.
# Never set this higher than the real number of proxies: each extra hop reads
# one position further left in a header the client controls, which lets callers
# forge their own IP and bypass IP-based rate limiting.
TRUSTED_PROXY_HOPS=0

# Ingestion — shared secret for POST /api/v1/ingest/run (cron/manual trigger).
# Leave unset to disable the endpoint. Set the same value as the GitHub
# Actions INGEST_TOKEN secret.
INGEST_TOKEN=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# AI / Embeddings
AI_FEATURES_ENABLED=false
LLM_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Rate limiting — global per-identity budget (fixed window)
RATE_LIMIT_ANONYMOUS_PER_MINUTE=60
RATE_LIMIT_AUTHENTICATED_PER_MINUTE=300
RATE_LIMIT_ADMIN_PER_MINUTE=1000

# Rate limiting — stricter per-route budgets (sliding window) for expensive/abusable routes
RATE_LIMIT_SEARCH_PER_MINUTE=30
RATE_LIMIT_WRITE_PER_MINUTE=40
RATE_LIMIT_PING_PER_MINUTE=20
